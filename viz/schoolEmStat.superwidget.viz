        "w": 284,
        "h": 20,
        "zIndex": 20,
        "props": {
          "text": "EmStat potentiostat · Square-Wave Voltammetry",
          "fontSize": "10pt",
          "fontColor": "#64748b",
          "textAlign": "left"
        }
      },
      {
        "id": "w-status",
        "type": "widgets/Label",
        "label": "Connection",
        "x": 300,
        "y": 84,
        "w": 284,
        "h": 28,
        "zIndex": 20,
        "props": {
          "text": "○ Offline",
          "fontSize": "13pt",
          "fontColor": "#94a3b8",
          "textAlign": "left"
        },
        "slotBindings": [
          {
            "slot": "text",
            "source": {
              "kind": "point",
              "connId": "sensorRead",
              "project": "sensorRead",
              "pointId": "p:sensorRead:r:316c1424-e08b6a11",
              "mode": "cur",
              "dis": "Connected",
              "map": [
                {
                  "eq": true,
                  "out": "● Connected"
                },
                {
                  "else": true,
                  "out": "○ Offline"
                }
              ]
            }
          },
          {
            "slot": "fontColor",
            "source": {
              "kind": "point",
              "connId": "sensorRead",
              "project": "sensorRead",
              "pointId": "p:sensorRead:r:316c1424-e08b6a11",
              "mode": "cur",
              "map": [
                {
                  "eq": true,
                  "out": "#16a34a"
                },
                {
                  "else": true,
                  "out": "#dc2626"
                }
              ]
            }
          }
        ]
      },
      {
        "id": "w-table",
        "type": "widgets/Grid",
        "label": "Live status",
        "x": 300,
        "y": 120,
        "w": 284,
        "h": 300,
        "zIndex": 20,
        "props": {
          "title": "Live status",
          "showHeader": true
        },
        "slotBindings": [
          {
            "slot": "in",
            "source": {
              "kind": "axon",
              "axon": "readAll(point and equipRef==@p:sensorRead:r:316c141b-86a4a8ce).map(r=>{metric:r[\"navName\"], value:r[\"curVal\"].toStr}).toGrid"
            }
          }
        ]
      }
    ],
    "logicGraphId": "g-schoolEmStat",
    "inPorts": [
