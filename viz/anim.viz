     "links": [
      "value"
     ]
    },
    {
     "anim": "intake",
     "links": [
      "value"
     ]
    }
   ],
   "machine": {
    "initial": "idle",
    "states": {
     "idle": {
      "on": {
       "GO": {
        "target": "running",
        "guard": "isOn"
       }
      }
     },
