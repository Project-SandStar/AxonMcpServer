{
  "name": "axon-mcp-server",
  "version": "1.0.0",
  "description": "MCP server providing Axon code examples and patterns",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/generated dist/",
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' tsx src/index.ts",
    "start": "node --max-old-space-size=8192 dist/index.js",
    "start:http": "MCP_TRANSPORT=http MCP_PORT=3847 node --max-old-space-size=8192 dist/index.js",
    "stop": "bash scripts/stop-server.sh",
    "status": "bash scripts/status-server.sh",
    "test": "jest",
    "cache:clear": "node scripts/clear-cache.js",
    "cache:clear:all": "rm -rf .cache",
    "sync": "npm run build && node dist/sync/sync-functions-cli.js",
    "daemon:start": "MCP_TRANSPORT=http MCP_PORT=3847 pm2 start dist/index.js --name axon-mcp --node-args='--max-old-space-size=8192'",
    "daemon:stop": "pm2 stop axon-mcp",
    "daemon:restart": "pm2 restart axon-mcp",
    "daemon:status": "pm2 status axon-mcp",
    "daemon:logs": "pm2 logs axon-mcp",
    "daemon:delete": "pm2 delete axon-mcp",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "dashboard:install": "cd dashboard && npm install"
  },
  "keywords": [
    "axon",
    "mcp",
    "haystack",
    "hvac",
    "building-automation"
  ],
  "private": true,
  "author": "Anka Labs, Inc. (https://ankalabs.com)",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@prisma/adapter-better-sqlite3": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^24.5.1",
    "@types/unzipper": "^0.10.11",
    "archiver": "^7.0.1",
    "axios": "^1.12.2",
    "dotenv": "^17.2.2",
    "express": "^5.2.1",
    "flexsearch": "^0.7.31",
    "haystack-core": "^3.0.6",
    "haystack-nclient": "^4.0.4",
    "haystack-units": "^2.0.6",
    "jest": "^30.1.3",
    "minimatch": "^10.0.3",
    "prisma": "^7.2.0",
    "ts-jest": "^29.4.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "unzipper": "^0.12.3",
    "web-tree-sitter": "^0.26.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/flexsearch": "^0.7.3"
  }
}
