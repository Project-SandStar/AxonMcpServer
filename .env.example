# Axon MCP Server — environment variables
# Copy to `.env` and fill in. `.env*` is git-ignored (except this example).
# Precedence: axon-config.json > environment variables > defaults (src/config/config.ts).

# ── Transport ───────────────────────────────────────────────
# "stdio" (default, for MCP clients) or "http" (dashboard + OAuth)
MCP_TRANSPORT=stdio
# HTTP port when MCP_TRANSPORT=http
MCP_PORT=3847

# ── Secrets ─────────────────────────────────────────────────
# Required to encrypt admin/app secrets at rest. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AXON_SECRET_KEY=

# Anthropic API key (only used by AI-assisted code generation / the VSCode extension)
ANTHROPIC_API_KEY=

# ── SkySpark sync / discovery ───────────────────────────────
# Directory holding SkySpark connection profiles (default: ./config)
SKYSPARK_CONFIG_DIR=./config
SKYSPARK_AUTO_DISCOVER=true
SKYSPARK_AUTO_SYNC_FUNCTIONS=true
SKYSPARK_SYNC_CONCURRENCY=4
SKYSPARK_FUNCTION_VERSIONING=true
SKYSPARK_MAX_VERSIONS=10
SKYSPARK_ENHANCED_PARSING=true

# ── Embeddings (semantic search; optional) ──────────────────
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=
# EMBEDDING_BATCH_SIZE=
# EMBEDDING_THREADS=
# DOCS_EMBEDDING_MODEL=
# DOCS_EMBEDDING_DIMENSIONS=
# WORKFLOW_EMBEDDING_DIMENSIONS=

# ── Runtime ─────────────────────────────────────────────────
NODE_ENV=production
# DEBUG=
